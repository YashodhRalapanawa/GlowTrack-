<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Enhanced header with gradient background -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_mood"
            android:paddingHorizontal="28dp"
            android:paddingTop="64dp"
            android:paddingBottom="48dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mood Tracker"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Understand your emotions"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:alpha="0.9" />

            </LinearLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Enhanced mood summary card with circular progress -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/card_mood"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Mood"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Circular Mood Visualization -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/circular_progress_mood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:progress="70"
                            app:trackCornerRadius="8dp"
                            app:trackThickness="12dp"
                            app:indicatorSize="200dp"
                            app:indicatorColor="@color/primary_green"
                            app:trackColor="@color/progress_incomplete" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_current_mood_emoji"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="😊"
                                android:textSize="48sp"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:id="@+id/tv_current_mood_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Happy"
                                android:textColor="@color/text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_mood_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="2:30 PM"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </FrameLayout>

                    <!-- Mood Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <!-- Total Entries -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="32dp"
                                app:cardElevation="4dp"
                                app:cardBackgroundColor="@color/primary_green_light">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="16dp"
                                    android:src="@drawable/ic_mood"
                                    app:tint="@color/primary_green" />

                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Entries"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_total_entries"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/primary_green"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="5" />

                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="60dp"
                            android:background="@color/divider_color"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="16dp" />

                        <!-- Avg Mood -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="32dp"
                                app:cardElevation="4dp"
                                app:cardBackgroundColor="@color/accent_light">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="16dp"
                                    android:src="@drawable/ic_trending_up"
                                    app:tint="@color/accent" />

                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Avg Mood"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_avg_mood"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/accent"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="3.2" />

                        </LinearLayout>

                        <!-- Streak -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                app:cardCornerRadius="32dp"
                                app:cardElevation="4dp"
                                app:cardBackgroundColor="@color/secondary_light">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="16dp"
                                    android:src="@drawable/ic_fire"
                                    app:tint="@color/secondary" />

                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Streak"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tv_mood_streak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/secondary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="7 days" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Enhanced action buttons with better styling -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_share_mood"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:layout_marginEnd="12dp"
                            android:paddingHorizontal="24dp"
                            android:text="Share Today"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            android:enabled="false"
                            app:strokeColor="@color/primary_green"
                            app:strokeWidth="2dp"
                            app:cornerRadius="28dp"
                            app:icon="@drawable/ic_share"
                            app:iconGravity="textStart" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_mood"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:paddingHorizontal="28dp"
                            android:text="Log Mood"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:enabled="false"
                            app:backgroundTint="@color/primary_green"
                            app:cornerRadius="28dp"
                            app:icon="@drawable/ic_check"
                            app:iconGravity="textStart" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Enhanced mood selector card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/card_mood"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How are you feeling?"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Select your current mood"
                        android:textColor="@color/text_secondary"
                        android:textSize="15sp" />

                    <!-- Mood selector with better layout -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_mood_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="10"
                        tools:listitem="@layout/item_mood_selector" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Enhanced mood trend card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/card_mood"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mood Trend"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />

                        <com.google.android.material.chip.ChipGroup
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleLine="true"
                            app:chipSpacingHorizontal="8dp">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trend_7days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="7 Days"
                                android:checked="true"
                                app:chipBackgroundColor="@color/chip_background_selector" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_trend_30days"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="30 Days"
                                app:chipBackgroundColor="@color/chip_background_selector" />

                        </com.google.android.material.chip.ChipGroup>

                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chart_mood_trend"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="20dp"
                        android:nestedScrollingEnabled="true" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Enhanced mood history section with tabs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/card_mood"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mood History"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tab_layout_mood_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:tabTextColor="@color/text_secondary"
                        app:tabSelectedTextColor="@color/primary_green"
                        app:tabIndicatorColor="@color/primary_green"
                        app:tabIndicatorHeight="3dp"
                        app:tabIndicatorFullWidth="false"
                        app:tabMode="fixed"
                        app:tabTextAppearance="@style/TextAppearance.Material3.BodyMedium" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_mood_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_mood_history" />

                    <!-- Calendar View -->
                    <ScrollView
                        android:id="@+id/layout_mood_calendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:visibility="gone"
                        tools:visibility="gone" />

                    <!-- Enhanced empty state with better visuals -->
                    <LinearLayout
                        android:id="@+id/layout_empty_mood_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="40dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="32dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/surface_variant">

                            <ImageView
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:padding="20dp"
                                android:src="@drawable/ic_mood"
                                app:tint="@color/primary_green" />

                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="No mood entries yet"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Start tracking your mood above\nto see your emotional journey"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Mood Insights Section -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="@color/card_mood"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="28dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mood Insights"
                                android:textColor="@color/text_primary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Your emotional patterns and trends"
                                android:textColor="@color/text_secondary"
                                android:textSize="15sp" />

                            <!-- Mood Distribution Chart (Pie Chart) -->
                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/chart_mood_distribution"
                                android:layout_width="match_parent"
                                android:layout_height="250dp"
                                android:layout_marginTop="20dp"
                                android:nestedScrollingEnabled="true" />

                            <!-- Mood Insights Cards -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="24dp"
                                android:baselineAligned="false">

                                <!-- Most Frequent Mood -->
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    app:cardCornerRadius="16dp"
                                    app:cardElevation="2dp"
                                    app:cardBackgroundColor="@color/surface_color">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:padding="16dp"
                                        android:gravity="center">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Most Frequent"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="13sp" />

                                        <TextView
                                            android:id="@+id/tv_most_frequent_mood"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:text="😊"
                                            android:textSize="28sp" />

                                        <TextView
                                            android:id="@+id/tv_most_frequent_mood_label"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:text="Happy"
                                            android:textColor="@color/text_primary"
                                            android:textSize="14sp"
                                            android:textStyle="bold" />

                                    </LinearLayout>

                                </com.google.android.material.card.MaterialCardView>

                                <!-- Mood Consistency -->
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    app:cardCornerRadius="16dp"
                                    app:cardElevation="2dp"
                                    app:cardBackgroundColor="@color/surface_color">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:padding="16dp"
                                        android:gravity="center">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Consistency"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="13sp" />

                                        <TextView
                                            android:id="@+id/tv_mood_consistency"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="8dp"
                                            android:text="75%"
                                            android:textColor="@color/primary_green"
                                            android:textSize="24sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="4dp"
                                            android:text="of days tracked"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="12sp" />

                                    </LinearLayout>

                                </com.google.android.material.card.MaterialCardView>

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>